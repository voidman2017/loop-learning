{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning State Schema",
  "description": "机器学习状态的 canonical JSON 格式",
  "type": "object",
  "required": ["version", "updated_at", "phase", "kill_switch", "current_theme"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema 版本号"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "最后更新时间"
    },
    "phase": {
      "type": "string",
      "enum": ["L1", "L2", "L3"],
      "description": "当前自动化级别"
    },
    "kill_switch": {
      "type": "boolean",
      "description": "紧急停机开关"
    },
    "focus_window": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$",
      "description": "当前聚焦窗口"
    },
    "current_theme": {
      "type": "array",
      "items": { "type": "string" },
      "description": "当前学习主题列表"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "状态置信度"
    },
    "active_goals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "当前活跃目标"
    },
    "progress": {
      "type": "object",
      "properties": {
        "total_study_hours_this_week": { "type": "number" },
        "new_notes_count": { "type": "integer" },
        "new_research_count": { "type": "integer" },
        "pending_review_count": { "type": "integer" },
        "high_risk_forget_topics": {
          "type": "array", "items": { "type": "string" }
        }
      }
    },
    "blind_spots": {
      "type": "array", "items": { "type": "string" },
      "description": "已识别的知识盲区"
    },
    "pending_human_decisions": {
      "type": "array", "items": { "type": "string" },
      "description": "待人工决策事项"
    },
    "recent_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "description": { "type": "string" }
        },
        "required": ["date", "description"]
      },
      "description": "最近变更记录"
    }
  }
}